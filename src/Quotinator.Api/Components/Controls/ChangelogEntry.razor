@using Quotinator.Changelog.Models

<details class="mb-2 changelog-entry" data-version="@(IsUnreleased ? "unreleased" : Release.Version)" open="@IsOpen">
    <summary class="py-1 user-select-none" style="cursor:pointer">
        @if (IsUnreleased)
        {
            <strong>@Text.ChangelogUnreleased</strong>
        }
        else
        {
            <strong>v@(Release.Version)</strong>
            <span class="text-muted ms-2">@Release.Date</span>
        }
    </summary>
    <div class="mt-2 ps-3">
        @if (Release.Highlights.Count > 0)
        {
            <ul class="mb-1">
                @foreach (var item in Release.Highlights)
                {
                    <li>@FormatInline(item)</li>
                }
            </ul>
            @if (!IsUnreleased)
            {
                <a class="small text-muted" target="_blank" rel="noopener noreferrer"
                   href="https://github.com/DutchJaFO/Quotinator/releases/tag/v@(Release.Version)">@Text.ChangelogFullDetailsOnGitHub</a>
            }
        }
        else
        {
            @foreach (var section in Release.Sections)
            {
                <h6 class="mt-2 mb-1">
                    <span class="badge @CategoryBadgeClass(section.Category)">@section.Category</span>
                </h6>
                <ul class="mb-1">
                    @foreach (var item in section.Items)
                    {
                        <li>@FormatInline(item)</li>
                    }
                </ul>
            }
        }
        @if (HasReferences)
        {
            <details class="mt-2">
                <summary class="small text-muted" style="cursor:pointer">@Text.ChangelogReferencesSummary</summary>
                <ul class="mt-1 mb-0 small">
                    @foreach (var issue in Release.Issues)
                    {
                        <li><a href="https://github.com/DutchJaFO/Quotinator/issues/@issue" target="_blank" rel="noopener noreferrer">#@issue</a></li>
                    }
                    @foreach (var cve in Release.Cves)
                    {
                        <li><a href="https://nvd.nist.gov/vuln/detail/@cve" target="_blank" rel="noopener noreferrer">@cve</a></li>
                    }
                </ul>
            </details>
        }
    </div>
</details>
