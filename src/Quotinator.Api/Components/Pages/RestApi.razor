@page "/rest-api"

<PageTitle>@Text.RestApiHeading — Quotinator</PageTitle>

<h1>@Text.RestApiHeading</h1>
<p>@Text.RestApiDescription</p>

<p>
    <a class="btn btn-primary" href="@ApiRoutes.ScalarUi.AsLink()">@Text.OpenApiButtonLabel</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>@Text.EndpointColumn</th>
            <th>@Text.UrlColumn</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>@Text.OpenApiUiLabel</td>
            <td><a href="@ApiRoutes.ScalarUi.AsLink()">@ApiRoutes.ScalarUi.AsLink()</a></td>
        </tr>
        <tr>
            <td>@Text.OpenApiSpecLabel</td>
            <td><a href="@ApiRoutes.OpenApiSpec.AsLink()">@ApiRoutes.OpenApiSpec.AsLink()</a></td>
        </tr>
        <tr>
            <td>@Text.HealthCheckLabel</td>
            <td><a href="@ApiRoutes.Health.AsLink()">@ApiRoutes.Health.AsLink()</a></td>
        </tr>
        <tr>
            <td>@Text.VersionLabel</td>
            <td><a href="@ApiRoutes.Version.AsLink()">@ApiRoutes.Version.AsLink()</a></td>
        </tr>
    </tbody>
</table>

@if (AdminKeyConfigured)
{
    <hr />

    <h2>@Text.AdminEndpointsHeading</h2>
    <p>@Text.AdminEndpointsDescription</p>

    <table class="table">
        <thead>
            <tr>
                <th>@Text.EndpointColumn</th>
                <th>@Text.UrlColumn</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@Text.AdminPreviewSeedLabel</td>
                <td><code>GET @ApiRoutes.DatabaseSeedPreview</code></td>
            </tr>
            <tr>
                <td>@Text.AdminReseedLabel</td>
                <td><code>POST @ApiRoutes.DatabaseReseed</code></td>
            </tr>
            <tr>
                <td>@Text.AdminResetLabel</td>
                <td><code>POST @ApiRoutes.DatabaseReset</code></td>
            </tr>
            <tr>
                <td>@Text.AdminAuditLogLabel</td>
                <td><code>GET @ApiRoutes.AuditLog</code></td>
            </tr>
            <tr>
                <td>@Text.AdminClearAuditLogLabel</td>
                <td><code>DELETE @ApiRoutes.AuditLog</code></td>
            </tr>
        </tbody>
    </table>

    <hr />

    <h2>@Text.ImportEndpointsHeading</h2>
    <p>@Text.ImportEndpointsDescription</p>

    <table class="table">
        <thead>
            <tr>
                <th>@Text.EndpointColumn</th>
                <th>@Text.UrlColumn</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@Text.ImportLabel</td>
                <td><code>POST @ApiRoutes.Import</code></td>
            </tr>
            <tr>
                <td>@Text.ImportPreviewLabel</td>
                <td><code>POST @ApiRoutes.ImportPreview</code></td>
            </tr>
            <tr>
                <td>@Text.ImportConflictsLabel</td>
                <td><code>GET @ApiRoutes.ImportConflicts</code></td>
            </tr>
            <tr>
                <td>@Text.ImportConflictsDecideLabel</td>
                <td><code>POST @ApiRoutes.ImportConflictsDecide</code></td>
            </tr>
            <tr>
                <td>@Text.ImportConflictsUndoLabel</td>
                <td><code>POST @ApiRoutes.ImportConflictsUndo</code></td>
            </tr>
            <tr>
                <td>@Text.ImportConflictsApplyLabel</td>
                <td><code>POST @ApiRoutes.ImportConflictsApply</code></td>
            </tr>
        </tbody>
    </table>
}

<hr />

<h2>@Text.TranslationsHeading</h2>
<p>@Text.TranslationsQuoteContent</p>
<p>@Text.TranslationsUi</p>
