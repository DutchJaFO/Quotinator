{
  "$schema": "../../schemas/manifest.schema.json",
  "duplicateResolution": {
    "default": "skip"
  },
  "files": [
    {
      "file": "quotinator-curated.json",
      "name": "quotinator/curated"
    },
    {
      "file": "NikhilNamal17_popular-movie-quotes.json",
      "name": "NikhilNamal17/popular-movie-quotes",
      "github": {
        "owner": "NikhilNamal17",
        "repo": "popular-movie-quotes",
        "path": "data/data.json",
        "branch": "master"
      },
      "converter": "basic-json-array",
      "converterOptions": {
        "propertyMapping": {
          "source": "movie",
          "date": "year"
        }
      }
    },
    {
      "file": "vilaboim_movie-quotes.json",
      "name": "vilaboim/movie-quotes",
      "github": {
        "owner": "vilaboim",
        "repo": "movie-quotes",
        "path": "movie-quotes.json",
        "branch": "master"
      },
      "converter": "regex-array",
      "converterOptions": {
        "pattern": "^\"(.+?)\"\\s+(.+)$",
        "groupMapping": {
          "quote": 1,
          "source": 2
        }
      }
    },
    {
      "file": "quotinator-series-universe.json",
      "name": "quotinator/series-universe",
      "duplicateResolution": {
        "default": "review"
      }
    }
  ]
}
