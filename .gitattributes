# Normalise all text files to LF in the repository and on checkout.
# This avoids CRLF/LF mismatches from tools (Dependabot, CI) that always write LF.
* text=auto eol=lf

# Binary — no line ending conversion
*.png       binary
*.ico       binary
*.jpg       binary
*.woff2     binary
*.woff      binary
*.ttf       binary
